# ─────────────────────────────────────────────────────────────────────────────
# Fitness Factory KC — environment variables
# Copy to .env.local for local dev, and set these in Vercel for production.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — session signing secret. Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# REQUIRED in production — data storage (Vercel KV or Upstash Redis).
# On Vercel: Storage tab → create a KV / Upstash database → these are injected
# automatically. For Upstash directly, use the UPSTASH_* names instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# OPTIONAL — send invitation emails automatically (https://resend.com).
# Without these, invites still work: the admin gets a shareable link to send.
RESEND_API_KEY=
INVITE_FROM_EMAIL=invites@yourdomain.com

# OPTIONAL — restrict who can be an owner. Comma-separated emails. Only these
# emails can create/hold the owner account; everyone else is invite-only.
# Strongly recommended on a public URL so nobody else can claim ownership.
OWNER_EMAILS=you@yourgym.com

# OPTIONAL — protect owner sign-up on a public URL. If set, creating the very
# first (owner) account requires this code, so a stranger can't claim it.
# (Only used when OWNER_EMAILS is NOT set.)
OWNER_SETUP_CODE=

# OPTIONAL — force invite links to use a specific public URL (e.g. your custom
# domain). On Vercel the production domain is detected automatically; set this
# only to override it.
APP_URL=

# OPTIONAL but recommended — progress-photo storage (Vercel Blob).
# On Vercel: Storage tab → create a Blob store → this is injected automatically.
# Without it, photos still work but are stored inline (larger); add it for real
# image hosting and cross-device sync.
BLOB_READ_WRITE_TOKEN=
